# Public HTTP port for the blog site.
HOST_PORT=8080

# Public HTTP port for the editor site. Must be different from HOST_PORT.
EDITOR_PORT=8081

# Asset directory name under the markdown source and blog output.
ASSETS_DIR=_assets

# Waline JWT secret. Required in production; use a long random secret.
WALINE_JWT_TOKEN=replace-with-a-long-random-secret

# Site name displayed in Waline.
WALINE_SITE_NAME=Blog Comments

# Canonical public URL of your site.
WALINE_SITE_URL=http://127.0.0.1:8080

# Optional public base URL for Waline when served behind a reverse proxy or tunnel.
# Example: https://example.com/waline
WALINE_SERVER_URL=
