# MarkCompose baseline environment file.
#
# Usage:
#   cp .env.example .env
#   ./markcompose.sh start <markdown_dir>
#
# `./markcompose.sh start` will merge this baseline file into `.env.runtime`,
# then write runtime-managed keys such as MARKDOWN_DIR / EDITOR_STATIC_DIR / ports.
#
# Adapter note:
# - Adapter is optional and enabled from CLI, not from this file.
# - Example:
#     ./markcompose.sh start --content-adapter adapter/prepare_content.sh <markdown_dir>

# Core ports
# Blog site HTTP port.
HOST_PORT=8080

# Editor site HTTP port. Must be different from HOST_PORT.
EDITOR_PORT=8081

# Asset directory name under the markdown source and blog output.
ASSETS_DIR=_assets

# Public site URL used by Hugo --baseURL during builds.
# Also used as Waline SITE_URL.
# Local default when omitted: http://127.0.0.1:${HOST_PORT}/
HUGO_BASE_URL=

# Waline
# Required in production; use a long random secret.
WALINE_JWT_TOKEN=replace-with-a-long-random-secret

# Optional site name shown in Waline.
WALINE_SITE_NAME=Blog Comments

# Optional override for Waline API/admin base URL.
# Usually leave empty unless you are behind a tunnel/reverse proxy and need an explicit public URL.
# Example: https://example.com/waline
WALINE_SERVER_URL=
